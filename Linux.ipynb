        "6.# Step 1: Create user p1\n",
        "\n",
        "```bash\n",
        "    sudo useradd p1\n",
        "    sudo passwd p1\n",
        "```\n",
        "# Step 2: Make p1 a member of groups g1, g2, and g3\n",
        " #Create the groups\n",
        "   ```bash\n",
        "      sudo groupadd g1\n",
        "      sudo groupadd g2\n",
        "      sudo groupadd g3\n",
        "    ```\n",
        "\n",
        " #Add user to groups\n",
        "   ```bash\n",
        "      sudo usermod -aG g1,g2,g3 p1\n",
        "  ```\n",
        " # To verify\n",
        "    ```bash\n",
        "      groups p1\n",
        "    ```\n",
        "#Step3: whenever he creates a file automatically in the group section of file grp g1 should come.\n",
        " #Set g1 as the primary group.\n",
        "   ```bash\n",
        "      sudo usermod -g g1 p1\n",
        "   ```\n"
      ]
    },
